---
import Github from "./Github.astro";

interface Props {
  title: string;
  githubUrl: string;
}

const { title, githubUrl } = Astro.props;
---

<nav class="pt-6 sm:pt-8 md:pt-12">
  <div class="flex justify-end px-8 md:px-16 mb-0.5 md:mb-2">
    <a
      href={githubUrl}
      class="text-black hover:text-red-500"
      target="_blank"
      rel="noopener noreferrer"
      title="访问网页Github仓库"
      aria-label="访问网页Github仓库"
    >
      <Github />
    </a>
  </div>

  <div class="mx-auto flex justify-center">
    <h1
      class="scale-x-[0.82] sm:scale-x-[0.85] md:scale-x-[0.8] 
      tracking-[-0.1em] sm:tracking-[-0.085em] md:tracking-[-0.075em] 
      text-[1.46rem] sm:text-[1.59rem] md:text-5xl 
      text-red-500 mb-1 md:mb-2 font-xiaobiaosong text-center"
    >
      {title}
    </h1>
  </div>
  <div class="px-8 md:px-16">
    <div class="border-b-3 md:border-b-4 border-red-500 mx-auto container mb-0.5"></div>
    <div class="border-b-1 md:border-b-2 border-red-500 mx-auto container"></div>
  </div>
</nav>
