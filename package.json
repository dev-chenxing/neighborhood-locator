{
  "name": "neighborhood-locator",
  "version": "3.0.1",
  "description": "A simple script that helps finding its neighborhood given a street address and street data",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.js",
      "default": "./index.js"
    },
    "./resolver": {
      "types": "./index.d.ts",
      "require": "./resolver.js",
      "default": "./resolver.js"
    },
    "./streets.json": "./streets.json"
  },
  "scripts": {},
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dev-chenxing/neighborhood-locator.git"
  },
  "keywords": [
    "xlsx"
  ],
  "author": "chenxing",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dev-chenxing/neighborhood-locator/issues"
  },
  "homepage": "https://github.com/dev-chenxing/neighborhood-locator#readme",
  "dependencies": {
    "exceljs": "^4.4.0",
    "rich-console": "0.0.4",
    "yargs": "^17.7.2"
  }
}
