{
  "name": "neighborhood-locator",
  "version": "4.0.0",
  "private": true,
  "description": "根据街道地址查找所属社区，适用于广州市白云区同德街",
  "keywords": [
    "xlsx"
  ],
  "homepage": "https://github.com/dev-chenxing/neighborhood-locator#readme",
  "bugs": {
    "url": "https://github.com/dev-chenxing/neighborhood-locator/issues"
  },
  "license": "MIT",
  "author": "陈刑",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dev-chenxing/neighborhood-locator.git"
  },
  "main": "./index.ts",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./index.ts",
      "default": "./index.ts"
    },
    "./resolver": {
      "types": "./index.d.ts",
      "require": "./resolver.ts",
