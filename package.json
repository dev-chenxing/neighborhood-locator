    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "@types/yargs": "^17.0.35",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0"
  },
  "peerDependencies": {
    "typescript": "^7.0.2"
  }
